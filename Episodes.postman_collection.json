{
  "info": {
    "name": "Episodes API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "email",
      "value": "user@example.com"
    },
    {
      "key": "password",
      "value": "Password1!"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "tv_show_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Health Check (Detailed)",
          "request": {
            "method": "GET",
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/health/verify",
              "host": ["{{baseUrl}}"],
              "path": ["health", "verify"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login?useCookies=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"],
              "query": [
                {
                  "key": "useCookies",
                  "value": "false"
                }
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste-refresh-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Me",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Shows",
      "item": [
        {
          "name": "Search Shows",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.results && json.results.length > 0) {",
                  "        pm.collectionVariables.set('tv_show_id', json.results[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shows/search?query=breaking bad&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "breaking bad"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Show",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shows/1396",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "1396"]
            }
          }
        },
        {
          "name": "Get Season Episodes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shows/1396/season/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "1396", "season", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Watchlist",
      "item": [
        {
          "name": "Get Watchlist",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/watchlist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist"]
            }
          }
        },
        {
          "name": "Add Show to Watchlist",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/{{tv_show_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", "{{tv_show_id}}"]
            }
          }
        },
        {
          "name": "Remove Show from Watchlist",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/{{tv_show_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", "{{tv_show_id}}"]
            }
          }
        }
      ]
    }
  ]
}
